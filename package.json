{
  "name": "attendguard",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,lecturer,student -c blue,magenta,green \"npm run dev -w api\" \"npm run dev -w web-lecturer\" \"npm run dev -w web-student\"",
    "db:generate": "npm run db:generate -w api",
    "db:migrate": "npm run db:migrate -w api",
    "db:seed": "npm run db:seed -w api"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "prisma@6.19.3": true
  }
}
